{{ define "title" }}Setup{{ end }}

{{ define "main" }}
<main class="setup-page">

  <h2>Welcome!</h2>
  <h4>Create an admin user to begin using Communis</h4>
  {{ with .SetupUserForm.FieldErrors }}
  <output>
    <ul>
    {{ range $msg := . }}
    <li>{{$msg}}</li>
    {{ end }}
    </ul>
  </output>
  {{ end }}
  <form action="/setup" method="POST" autocomplete="off">
    <label for="uesrname">Username</label>
    <input id="username" type="text" name="username" class="text-input" value="{{ .SetupUserForm.Username }}">

    <label for="password">Password</label>
    <input id="password" type="password" name="password" class="text-input">

    <label for="confirm-password">Confirm Password</label>
    <input id="confirm-password" type="password" name="confirm-password" class="text-input">

    <button type="submit" class="text-button">Create</button>
  </form>
</main>


{{ end }}
