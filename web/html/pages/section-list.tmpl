{{ define "title" }} Sections {{ end }}

{{ define "main" }}
<main class="sections-list-page">
  <div class="sections-header">
    <h2 class="title">Sections</h2>
    <button type="button" class="newbtn" hx-get="/section/new" hx-target="#section-list" hx-swap="append">
      <svg>
	<use href="/static/vendor/svg/lucide-icons-sprite.svg#plus"/>
      </svg>
    </button>
</div>
<hr>
  <div id="section-list" class="sections-link-list">
    <ul class="links">
    {{ range .Sections }}

    <li><a href="/section/{{ .Id }}/{{ slugify .Name }}"> {{ .Name }}</a></li>
    {{ end }}
    </ul>
  </div>
</main>

{{ end }}
