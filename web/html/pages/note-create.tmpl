{{define "title"}} New Note {{end}}

{{define "main"}}

<form action="{{ .ActionDest }}" method="POST">

  <input type="text" id="title" name="title" value="{{ .Note.Title }}" placeholder="Title"/>
  
  <br>

  {{ with .FieldErrors.title  }}
  <label class="error">{{.}}</label>
  {{ end }}


  <div id="editor"></div>

  <label for="section">Section: </label>
  <select list="section-list" id="section" name="section">
    {{ range .AllSections }}
      {{ if eq .Name $.Note.Section.Name }}
      <option value="{{ .Name }}" selected>{{ .Name }}</option>
      {{ else }}
      <option value="{{ .Name }}">{{ .Name }}</option>
      {{ end }}
    {{ end }}
  </select>

  {{ with .FieldErrors.section }}
    <label class="error">{{ . }}</label>
  {{ end }}

    <fieldset>
      <legend>Tags:</legend>
      {{ with .FieldErrors.tags }}
      <label>{{ . }}</label>
      {{ end }}

      <div id="tags-container" data-tags>
	<div data-tags-list>
	{{ range .Note.Tags }}
	<div class="input-group">
	  <input type="text" name="tags-list" value="{{ .Name }}">
	  <button type="button" data-tags-remove>X</button>
	</div>
	{{ end }}
	</div>
      <button type="button" data-tags-add>+ Add Tag</button>
      </div>
    </fieldset>
    <br>
  <div>
    <input type="submit" value="Save" />
  </div>
</form>


{{end}}


{{define "scripts"}}
<script src="/static/js/add-tags.js"></script>
<script type="module">
  import OverType, { toolbarButtons } from '../../static/vendor/js/overtype_v2-1-0.esm.js';

  const [editor] = new OverType('#editor', {
      value: '{{ .Note.Content }}',
      toolbar: true,
      toolbarButtons: [
	  toolbarButtons.bold,
	  toolbarButtons.italic,
          toolbarButtons.code,
          toolbarButtons.link,
          toolbarButtons.h1,
          toolbarButtons.h2,
	  toolbarButtons.h3,
	  toolbarButtons.bulletList,
	  toolbarButtons.orderedList,
	  toolbarButtons.taskList,
	  toolbarButtons.quote,
	  toolbarButtons.separator,
      ],
      textareaProps: {
          name: 'content'
      },
      theme: 'cave',
  });
</script>
{{end}}
