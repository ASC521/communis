{{define "title"}} New Note {{end}}

{{define "main"}}

<form action="{{ .ActionDest }}" method="POST">

  <label for="title">Title: </label>
  <input type="text" id="title" name="title" value="{{ .Note.Title }}"/><br>

  {{ with .FieldErrors.title  }}
  <label class="error">{{.}}</label>
  {{ end }}


  <div id="editor"></div>

  <label for="section">Section: </label>
  <select list="section-list" id="section" name="section">
    {{ range .AllSections }}
      {{ if eq .Name $.Note.Section.Name }}
      <option value="{{ .Name }}" selected>{{ .Name }}</option>
      {{ else }}
      <option value="{{ .Name }}">{{ .Name }}</option>
      {{ end }}
    {{ end }}
  </select>

  {{ with .FieldErrors.section }}
    <label class="error">{{ . }}</label>
  {{ end }}

    <fieldset>
      <legend>Tags:</legend>
      {{ with .FieldErrors.tags }}
      <label>{{ . }}</label>
      {{ end }}

      <div id="tags-container" data-tags>
	<div data-tags-list>
	{{ range .Note.Tags }}
	<div class="input-group">
	  <input type="text" name="tags-list" value="{{ .Name }}">
	  <button type="button" data-tags-remove>X</button>
	</div>
	{{ end }}
	</div>
      <button type="button" data-tags-add>+ Add Tag</button>
      </div>
    </fieldset>
    <br>
  <div>
    <input type="submit" value="Save" />
  </div>
</form>


{{end}}


{{define "scripts"}}
<script src="/static/vendor/js/overtype_v2-0-5.min.js"></script>
<script src="/static/js/add-tags.js"></script>
  <script>
    const [editor] = new OverType('#editor', {
        value: '{{ .Note.Content }}',
        toolbar: true,
        textareaProps: {
           name: 'content'
        }
    });
  </script>
{{end}}
