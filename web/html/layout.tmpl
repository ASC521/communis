{{define "layout"}}
<!doctype html>
<html lang='en' data-theme="{{ .Theme }}">
  <head>
    <meta charset='utf-8'>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="/static/vendor/js/htmx_v4-0-0_beta2.min.js"></script>
    <script src="/static/js/scripts.js?ver=1"></script>
    <script src="/static/js/markdown-editor.js?ver=1"></script>
    <link rel="stylesheet" href="/static/css/style.css?v=1">
    <link rel="stylesheet" href="/static/vendor/css/highlighting-{{.Theme}}.css?v=1">
    <title>{{template "title" . }}</title>
  </head>
  <body>

    {{ if .IsAuthenticated }}

	{{ if .IsAdmin }}
    
    		{{ template "navbar-admin" . }}

	{{ else }}
    
	    {{ template "navbar-authenticated" . }}
    
	{{ end }}
    
    {{ else }}
    
    	{{ template "navbar-unauthenticated" . }}
    
    {{ end }}


    {{ template "main" . }}

  </body>

</html>

{{end}}
