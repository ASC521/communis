{{ define "note-table" }}
{{ range . }}

<article class="search-result">
  <header>
    <h2>
      <a href="/note/{{.Id}}/{{ slugify .Title }}" hx-boost="true">{{ safeHTML .TitleHighlight }}</a>
    </h2>
  </header>
  {{ safeHTML .ContentSnippet }}
  <footer>
    <p>Tags: {{safeHTML .TagNames }}</p>
  </footer>
</article>

{{ end }}
{{ end }}
