{{ define "rendered-note" }}

<div class="rendered-note">
  <div class="title-row">
    <h1> {{ .Note.Title }}</h1>

    <div class="buttons">
      {{ if .IsPreview }}
      {{ if ne .Note.ID 0 }}
      <button type="button" hx-target="body" hx-delete="/note/{{ .Note.ID }}/{{ slugify .Note.Title }}"  hx-confirm="Delete {{ .Note.Title }}?" class="svg-button">
	<svg>
	  <use href="/static/vendor/svg/lucide-icons-sprite.svg#trash-2"/>
	</svg>
      </button>
      {{ end }}
      <button id="mde-preview-btn" type="button" class="svg-button">
	<svg class="icon">
	  <use href="/static/vendor/svg/lucide-icons-sprite.svg#eye-off"/>
	</svg>
      </button>
      {{ if eq .Note.ID 0 }}
      <button hx-post="/note" form="note-editor" class="svg-button">
	{{ else }}
	<button hx-put="/note/{{ .Note.ID }}/{{ slugify .Note.Title }}" form="note-editor" class="svg-button">
	{{ end }}
	<svg>
	  <use href="/static/vendor/svg/lucide-icons-sprite.svg#save"/>
	</svg>
      </button>
      {{ else }}
      <a class="svg-button" href="/edit/{{ .Note.ID }}/{{ slugify .Note.Title }}">
	<svg>
	  <use href="/static/vendor/svg/lucide-icons-sprite.svg#file-pen-line"/>
	</svg>
      </a>
      {{ end}}
    </div>
  </div>
  
  <details class="note-details">
    <summary>Details</summary>
    <dl class="details -compact">
      <dt><strong>Section:</strong></dt>
      <dd><a href="/section/{{ .Note.Section.ID }}/{{ .Note.Section.Name }}">{{ .Note.Section.Name }}</a></dd>

      <dt><strong>Tags:</strong></dt>
      <dd>
	{{ range .Note.Tags }}
	<a href="/tag/{{ .ID }}/{{ .Name }}">{{ .Name }}</a>
	{{ end }}
      </dd>

      <dt><strong>References:</strong></dt>
      <dd>
	{{ range .Note.ReferenceNotes }}
	<a href="/note/{{ .ID }}/{{ slugify .Title }}">{{ .Title }}</a>
	{{ end }}
      </dd>

      <dt><strong>Referenced By:</strong></dt>
      <dd>
	{{ range .Note.ReferenceByNotes }}
	<a href="/note/{{ .ID }}/{{ slugify .Title }}">{{ .Title }}</a>
	{{ end }}
      </dd>

      <dt><strong>Last Updated:</strong></dt>
      <dd><time class="local-time" datetime="{{ .Note.LastUpdatedAt }}"></time></dd>

      <dt><strong>Created:</strong></dt>
      <dd><time class="local-time" datetime="{{ .Note.CreatedAt }}"></time></dd>
    </dl>
  </details>
  <section class="rendered-markdown">
  {{ .RenderedHTML }}
  </section>
</div>

{{ end }}
