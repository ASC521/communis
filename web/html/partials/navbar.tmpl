{{ define "navbar" }}
<header>
<nav class="nav-bar">
  <ul class="links">
    <li><strong><a href="/">Home</a></strong></li>
    <li><strong><a href="/note/new">New Note</a></strong></li>
    <li><strong><a href="/section">Sections</a></strong></li>
    <li><strong><a href="/index">Index</a></strong></li>
    <li class="dropdown">
      <details>
	<summary>
	  Settings
	</summary>
	<ul>
	  {{ if .IsAuthenticated }}
	  <li><button class="text-button" id="theme-toggle-btn" hx-put="/user/{{ .UserId }}/theme">Toggle Theme</button></li>
	  <li><button class="text-button" hx-post="/logout">Logout</button></li>
	  {{ else }}
	  <li><button class="text-button" id="theme-toggle-btn" href="#">Toggle Theme</button></li>
	  <li><button class="text-button" href="/login">Login</button></li>
	  {{ end }}
	</ul>
      </details>
    </li>
  </ul>
</nav>
</header>
{{ end }}
