{{ define "new-tag" }}
{{ if ne .ErrMsg "" }}
<p>{{ .ErrMsg }}</p>
{{ else }}
<p>{{ .SuccessMsg }}</p>

<fieldset id="tag-selector" tabindex="0" hx-swap-oob="append:#tag-selector">
  <input type="checkbox" name="tags" id="tag-{{ .Tag.ID }}" value={{ .Tag.ID }} checked>
  <label for="tag-{{ .Tag.ID }}">{{ .Tag.Name }}</label>
</fieldset>
{{ end }}
{{ end }}
